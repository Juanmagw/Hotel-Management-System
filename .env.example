# Copia este archivo a .env y ajusta los valores (no subas .env al repositorio)

# Perfil activo: dev | cua | prod
SPRING_PROFILES_ACTIVE=dev

# Base de datos (cua / prod)
DB_URL=jdbc:postgresql://localhost:5432/hotel_db
DB_USERNAME=ADMIN0107
DB_PASSWORD=ADMIN010718

# JWT
JWT_SECRET=cambia-esta-clave-por-una-segura-de-al-menos-32-caracteres
JWT_EXPIRATION=86400000

# CORS (orígenes del frontend, separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Flyway (desactivar solo si necesitas arrancar sin migraciones)
FLYWAY_ENABLED=true

# --- Usuarios demo (perfil dev, se crean al primer arranque con BD vacía) ---
# admin@hotel.com       -> ADMIN
# recepcion@hotel.com   -> RECEPTIONIST
# guest@hotel.com       -> GUEST
# Contraseña para todos: Password123!
